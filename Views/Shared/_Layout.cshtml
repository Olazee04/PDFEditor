<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — NovaPDF Editor</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400;500&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <nav class="topnav">
        <a href="/" class="brand">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
                <rect width="28" height="28" rx="8" fill="#FF4D1C"/>
                <path d="M7 8h14M7 14h10M7 20h12" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
                <circle cx="21" cy="20" r="4" fill="white"/>
                <path d="M19.5 20h3M21 18.5v3" stroke="#FF4D1C" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <span>NovaPDF</span>
        </a>
        <div class="nav-links">
            <a href="/">Dashboard</a>
            <a href="#" class="nav-btn-upload" id="globalUploadBtn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12"/>
                </svg>
                Upload PDF
            </a>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <script src="~/js/site.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
