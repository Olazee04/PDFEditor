@model PDFEditor.Models.PdfDocument
@{
    ViewData["Title"] = "Edit — " + Model.FileName;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
<style>
:root {
    --sidebar-w: 300px;
    --toolbar-h: 52px;
    --ai-panel-w: 360px;
}
body { overflow: hidden; }
.topnav { display: none; }
main { padding: 0; }

/* ── Editor Shell ── */
.editor-shell {
    display: grid;
    grid-template-columns: var(--sidebar-w) 1fr var(--ai-panel-w);
    grid-template-rows: var(--toolbar-h) 1fr;
    height: 100vh;
    background: #0d0d14;
    font-family: 'Inter', sans-serif;
}

/* ── Top Toolbar ── */
.toolbar {
    grid-column: 1 / -1;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 0 16px;
    background: #111118;
    border-bottom: 1px solid #1f1f2e;
    z-index: 100;
}
.toolbar-brand {
    display: flex; align-items: center; gap: 8px;
    margin-right: 20px; text-decoration: none;
    color: white; font-family: 'Syne', sans-serif; font-weight: 700;
    font-size: 15px;
}
.toolbar-brand svg { flex-shrink: 0; }
.tb-sep { width: 1px; height: 24px; background: #2a2a3a; margin: 0 8px; }
.tb-btn {
    display: flex; align-items: center; gap: 6px;
    padding: 6px 12px; border: none; border-radius: 6px;
    background: transparent; color: #aaa;
    font-size: 12px; cursor: pointer; transition: all 0.15s;
    font-family: 'Inter', sans-serif;
}
.tb-btn:hover { background: #1f1f2e; color: white; }
.tb-btn.active { background: #FF4D1C22; color: #FF4D1C; }
.tb-btn svg { flex-shrink: 0; }
.tb-spacer { flex: 1; }
.tb-filename {
    font-size: 12px; color: #666;
    font-family: 'DM Mono', monospace;
    max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.tb-save-btn {
    background: #FF4D1C; color: white;
    padding: 6px 16px; border: none; border-radius: 6px;
    font-size: 12px; font-weight: 600; cursor: pointer;
    font-family: 'Inter', sans-serif; transition: opacity 0.2s;
}
.tb-save-btn:hover { opacity: 0.85; }

/* ── Left Sidebar ── */
.sidebar {
    background: #111118;
    border-right: 1px solid #1f1f2e;
    display: flex; flex-direction: column;
    overflow: hidden;
}
.sidebar-tabs {
    display: flex; border-bottom: 1px solid #1f1f2e;
}
.stab {
    flex: 1; padding: 10px 4px;
    background: none; border: none;
    color: #555; font-size: 11px;
    cursor: pointer; transition: all 0.15s;
    font-family: 'Inter', sans-serif;
    display: flex; flex-direction: column;
    align-items: center; gap: 4px;
}
.stab:hover { color: #aaa; }
.stab.active { color: #FF4D1C; border-bottom: 2px solid #FF4D1C; }
.stab-content { display: none; flex: 1; overflow-y: auto; padding: 12px; }
.stab-content.active { display: block; }

/* Page thumbnails */
.page-thumb {
    display: flex; align-items: center; gap: 10px;
    padding: 8px; border-radius: 8px;
    cursor: pointer; margin-bottom: 4px;
    transition: background 0.15s; border: 1px solid transparent;
}
.page-thumb:hover { background: #1a1a2a; }
.page-thumb.active { background: #FF4D1C14; border-color: #FF4D1C44; }
.page-num-badge {
    width: 24px; height: 24px; border-radius: 4px;
    background: #1f1f2e; color: #666;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-family: 'DM Mono', monospace; flex-shrink: 0;
}
.page-thumb.active .page-num-badge { background: #FF4D1C; color: white; }
.page-thumb-label { font-size: 12px; color: #888; }

/* Properties panels */
.prop-group { margin-bottom: 16px; }
.prop-label { font-size: 11px; color: #555; margin-bottom: 6px; letter-spacing: 0.05em; text-transform: uppercase; }
.prop-value {
    background: #0d0d14; border: 1px solid #1f1f2e;
    border-radius: 6px; padding: 8px 10px;
    font-size: 12px; color: #ccc;
    font-family: 'DM Mono', monospace;
}
.font-chip {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 4px 10px; border-radius: 20px;
    background: #1a1a2a; border: 1px solid #2a2a3a;
    color: #aaa; font-size: 11px; margin: 2px;
    font-family: 'DM Mono', monospace;
}
.suggestions-list { list-style: none; padding: 0; margin: 0; }
.suggestion-item {
    padding: 10px 12px; border-radius: 8px;
    background: #1a1a2a; margin-bottom: 6px;
    font-size: 12px; color: #aaa; cursor: pointer;
    transition: background 0.15s; border: 1px solid #2a2a3a;
    line-height: 1.4;
}
.suggestion-item:hover { background: #FF4D1C14; border-color: #FF4D1C44; color: #FF4D1C; }

/* History items */
.history-item {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 8px; border-radius: 6px; margin-bottom: 4px;
    border: 1px solid #1a1a2a;
}
.history-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: #FF4D1C; margin-top: 4px; flex-shrink: 0;
}
.history-text { font-size: 11px; color: #888; line-height: 1.4; }
.history-time { font-size: 10px; color: #444; font-family: 'DM Mono', monospace; }

/* ── Canvas Area ── */
.canvas-area {
    background: #0a0a12;
    display: flex; flex-direction: column;
    align-items: center; overflow: auto;
    position: relative;
}
.canvas-toolbar {
    position: sticky; top: 0; z-index: 50;
    width: 100%; background: #0d0d14;
    border-bottom: 1px solid #1f1f2e;
    display: flex; align-items: center;
    gap: 4px; padding: 6px 16px;
}
.zoom-ctrl {
    display: flex; align-items: center; gap: 6px;
    margin-left: auto;
}
.zoom-val { font-size: 12px; color: #666; font-family: 'DM Mono', monospace; min-width: 44px; text-align: center; }

.pdf-viewport-wrapper {
    flex: 1; display: flex;
    align-items: flex-start; justify-content: center;
    padding: 40px 20px;
}
#pdfViewport {
    position: relative;
    box-shadow: 0 8px 40px rgba(0,0,0,0.8);
    border: 1px solid #1f1f2e;
}
#pdfCanvas { display: block; }
#overlayCanvas {
    position: absolute; top: 0; left: 0;
    cursor: crosshair; pointer-events: auto;
}
.text-overlay {
    position: absolute;
    border: 1px dashed transparent;
    cursor: text; transition: border-color 0.15s;
    box-sizing: border-box;
}
.text-overlay:hover { border-color: #FF4D1C88; background: #FF4D1C0a; }
.text-overlay.selected { border-color: #FF4D1C; background: #FF4D1C14; }

/* Selection box */
#selectionBox {
    position: absolute; border: 1.5px dashed #FF4D1C;
    background: rgba(255,77,28,0.08); pointer-events: none;
    display: none;
}

/* ── AI Panel ── */
.ai-panel {
    background: #111118;
    border-left: 1px solid #1f1f2e;
    display: flex; flex-direction: column;
}
.ai-header {
    padding: 14px 16px;
    border-bottom: 1px solid #1f1f2e;
    display: flex; align-items: center; gap: 10px;
}
.ai-badge {
    display: flex; align-items: center; gap: 6px;
    font-family: 'Syne', sans-serif; font-weight: 700;
    font-size: 14px; color: white;
}
.ai-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: #FF4D1C; animation: pulse 2s ease-in-out infinite;
}
@@keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
}
.ai-subtitle { font-size: 11px; color: #555; margin-left: auto; }
.ai-messages {
    flex: 1; overflow-y: auto; padding: 12px;
    display: flex; flex-direction: column; gap: 10px;
    max-height: calc(100vh - 220px);
    scroll-behavior: smooth;
}
.ai-msg {
    max-width: 90%; padding: 10px 12px;
    border-radius: 10px; font-size: 12px; line-height: 1.5;
    word-wrap: break-word; overflow-wrap: break-word;
}
.ai-msg.user {
    align-self: flex-end;
    background: #FF4D1C; color: white; border-radius: 10px 10px 2px 10px;
}
.ai-msg.assistant {
    align-self: flex-start;
    background: #1a1a2a; color: #ccc; border-radius: 10px 10px 10px 2px;
    border: 1px solid #2a2a3a;
}
.ai-msg.system {
    align-self: center;
    background: #1f1f2e; color: #666;
    font-size: 11px; border-radius: 20px;
    padding: 6px 14px; font-family: 'DM Mono', monospace;
}
.operation-card {
    background: #0d0d14; border: 1px solid #FF4D1C44;
    border-radius: 8px; padding: 10px;
    margin-top: 6px; font-size: 11px;
}
.op-title { color: #FF4D1C; font-weight: 600; margin-bottom: 6px; font-family: 'DM Mono', monospace; }
.op-detail { color: #888; line-height: 1.5; }
.op-execute {
    margin-top: 8px; padding: 6px 12px;
    background: #FF4D1C; color: white; border: none;
    border-radius: 6px; font-size: 11px; cursor: pointer;
    font-family: 'Inter', sans-serif; font-weight: 600;
}
.ai-input-area {
    padding: 12px;
    border-top: 1px solid #1f1f2e;
}
.ai-input-wrap {
    display: flex; gap: 6px;
    background: #0d0d14; border: 1px solid #2a2a3a;
    border-radius: 10px; padding: 4px;
    transition: border-color 0.2s;
}
.ai-input-wrap:focus-within { border-color: #FF4D1C66; }
#aiInput {
    flex: 1; background: none; border: none; outline: none;
    color: #ccc; font-size: 12px; padding: 7px 10px;
    font-family: 'Inter', sans-serif; resize: none;
    max-height: 100px; min-height: 34px;
}
#aiInput::placeholder { color: #444; }
.ai-send-btn {
    width: 34px; height: 34px; border-radius: 8px;
    background: #FF4D1C; border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; align-self: flex-end;
    transition: opacity 0.2s;
}
.ai-send-btn:hover { opacity: 0.85; }
.ai-quick-btns {
    display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 8px;
}
.ai-quick {
    padding: 4px 10px; border-radius: 14px;
    background: #1a1a2a; border: 1px solid #2a2a3a;
    color: #888; font-size: 11px; cursor: pointer;
    transition: all 0.15s; font-family: 'Inter', sans-serif;
}
.ai-quick:hover { background: #FF4D1C1a; border-color: #FF4D1C44; color: #FF4D1C; }

/* Edit text modal */
.modal-backdrop {
    position: fixed; inset: 0; background: rgba(0,0,0,0.7);
    z-index: 1000; display: flex; align-items: center;
    justify-content: center; display: none;
}
.modal-backdrop.open { display: flex; }
.modal {
    background: #111118; border: 1px solid #2a2a3a;
    border-radius: 14px; padding: 24px; width: 480px;
    max-width: 95vw;
}
.modal-title {
    font-family: 'Syne', sans-serif; font-weight: 700;
    font-size: 16px; color: white; margin-bottom: 20px;
    display: flex; align-items: center; justify-content: space-between;
}
.modal-close { background: none; border: none; color: #555; cursor: pointer; font-size: 20px; }
.form-group { margin-bottom: 14px; }
.form-label { font-size: 11px; color: #666; margin-bottom: 6px; display: block; text-transform: uppercase; letter-spacing: 0.05em; }
.form-input, .form-select {
    width: 100%; padding: 8px 12px;
    background: #0d0d14; border: 1px solid #2a2a3a;
    border-radius: 8px; color: #ccc; font-size: 13px;
    outline: none; transition: border-color 0.2s;
    font-family: 'DM Mono', monospace; box-sizing: border-box;
}
.form-input:focus, .form-select:focus { border-color: #FF4D1C66; }
.form-row { display: flex; gap: 10px; }
.form-row .form-group { flex: 1; }
.modal-actions { display: flex; gap: 8px; justify-content: flex-end; margin-top: 20px; }
.btn-cancel { padding: 8px 16px; border-radius: 8px; background: #1a1a2a; border: 1px solid #2a2a3a; color: #888; font-size: 13px; cursor: pointer; }
.btn-apply { padding: 8px 20px; border-radius: 8px; background: #FF4D1C; border: none; color: white; font-size: 13px; font-weight: 600; cursor: pointer; }

/* Context menu */
.ctx-menu {
    position: fixed; background: #111118;
    border: 1px solid #2a2a3a; border-radius: 10px;
    padding: 6px; z-index: 500; min-width: 180px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.5);
    display: none;
}
.ctx-item {
    display: flex; align-items: center; gap: 8px;
    padding: 8px 12px; border-radius: 6px;
    font-size: 12px; color: #aaa; cursor: pointer;
    transition: background 0.1s;
}
.ctx-item:hover { background: #1a1a2a; color: white; }
.ctx-item.danger:hover { background: #FF4D1C22; color: #FF4D1C; }
.ctx-sep { height: 1px; background: #1f1f2e; margin: 4px 6px; }

/* Toast */
.toast-container { position: fixed; bottom: 20px; right: 20px; z-index: 2000; display: flex; flex-direction: column; gap: 8px; }
.toast {
    padding: 10px 16px; border-radius: 8px;
    font-size: 12px; font-family: 'Inter', sans-serif;
    animation: slideIn 0.2s ease;
    display: flex; align-items: center; gap: 8px;
}
.toast.success { background: #0d2818; border: 1px solid #1a5c33; color: #4caf79; }
.toast.error { background: #2a0f0f; border: 1px solid #5c1a1a; color: #ff6b6b; }
.toast.info { background: #111118; border: 1px solid #2a2a3a; color: #888; }
@@keyframes slideIn { from { opacity:0; transform: translateX(20px); } to { opacity:1; transform: none; } }

/* Loading overlay */
.loading-overlay {
    position: absolute; inset: 0;
    background: rgba(13,13,20,0.85);
    display: flex; align-items: center; justify-content: center;
    z-index: 200; display: none; flex-direction: column; gap: 12px;
}
.spinner {
    width: 36px; height: 36px; border-radius: 50%;
    border: 3px solid #1f1f2e;
    border-top-color: #FF4D1C;
    animation: spin 0.8s linear infinite;
}
@@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-size: 12px; color: #666; font-family: 'DM Mono', monospace; }

/* Scrollbars */
::-webkit-scrollbar { width: 4px; height: 4px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: #2a2a3a; border-radius: 4px; }
</style>
}

<div class="editor-shell">

    <!-- ── TOOLBAR ── -->
    <div class="toolbar">
        <a href="/" class="toolbar-brand">
            <svg width="22" height="22" viewBox="0 0 28 28" fill="none">
                <rect width="28" height="28" rx="8" fill="#FF4D1C"/>
                <path d="M7 8h14M7 14h10M7 20h12" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
            </svg>
            NovaPDF
        </a>
        <div class="tb-sep"></div>

        <button class="tb-btn active" id="toolSelect" title="Select" onclick="setTool('select')">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 3l14 9-7 1-3 7L5 3z"/>
            </svg>
            Select
        </button>
        <button class="tb-btn" id="toolText" title="Edit Text" onclick="setTool('text')">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/>
                <line x1="12" y1="4" x2="12" y2="20"/>
            </svg>
            Text
        </button>
        <button class="tb-btn" id="toolAnnotate" title="Annotate" onclick="setTool('annotate')">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 20h9M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/>
            </svg>
            Annotate
        </button>
        <button class="tb-btn" id="toolHighlight" title="Highlight" onclick="setTool('highlight')">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 11l3 3L22 4M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
            </svg>
            Highlight
        </button>
        <button class="tb-btn" id="toolRedact" title="Redact" onclick="setTool('redact')">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="9" x2="15" y2="15"/>
                <line x1="15" y1="9" x2="9" y2="15"/>
            </svg>
            Redact
        </button>
        <button class="tb-btn" onclick="showImageTools()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
            </svg>
            Images
        </button>
        <div class="tb-sep"></div>
        <button class="tb-btn" onclick="undoLast()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 7v6h6"/><path d="M21 17a9 9 0 00-9-9 9 9 0 00-6 2.3L3 13"/>
            </svg>
        </button>
        <button class="tb-btn" onclick="loadVersions()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/>
            </svg>
            History
        </button>

        <div class="tb-spacer"></div>
        <span class="tb-filename">@Model.FileName</span>
        <div class="tb-sep"></div>
        <a href="/Editor/Download/@Model.Id" class="tb-save-btn">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="display:inline;vertical-align:-2px;margin-right:4px">
                <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/>
            </svg>
            Download
        </a>
    </div>

    <!-- ── LEFT SIDEBAR ── -->
    <div class="sidebar">
        <div class="sidebar-tabs">
            <button class="stab active" onclick="switchTab('pages',this)">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="3" x2="9" y2="21"/></svg>
                Pages
            </button>
            <button class="stab" onclick="switchTab('props',this)">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 010 14.14M4.93 4.93a10 10 0 000 14.14"/></svg>
                Props
            </button>
            <button class="stab" onclick="switchTab('history',this)">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg>
                History
            </button>
        </div>

        <div id="tabPages" class="stab-content active">
            <div id="pageList"></div>
        </div>
        <div id="tabProps" class="stab-content">
            <div id="propsPanel">
                <p style="color:#555;font-size:12px;text-align:center;padding:20px 0">Select an element to see properties</p>
            </div>
        </div>
        <div id="tabHistory" class="stab-content">
            <div id="historyList">
                <p style="color:#555;font-size:12px;text-align:center;padding:20px 0">No history yet</p>
            </div>
        </div>
    </div>

    <!-- ── CANVAS AREA ── -->
    <div class="canvas-area" id="canvasArea">
        <div class="canvas-toolbar">
            <button class="tb-btn" onclick="changePage(-1)">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <span id="pageIndicator" style="font-size:12px;color:#666;font-family:'DM Mono',monospace">Page 1 / @Model.PageCount</span>
            <button class="tb-btn" onclick="changePage(1)">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
            <div class="zoom-ctrl">
                <button class="tb-btn" onclick="zoom(-0.25)">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/></svg>
                </button>
                <span class="zoom-val" id="zoomDisplay">100%</span>
                <button class="tb-btn" onclick="zoom(0.25)">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                </button>
                <button class="tb-btn" onclick="zoom(0,'fit')">Fit</button>
            </div>
        </div>

        <div class="pdf-viewport-wrapper">
            <div id="pdfViewport">
                <canvas id="pdfCanvas"></canvas>
                <canvas id="overlayCanvas"></canvas>
                <div id="selectionBox"></div>
                <div id="textOverlays"></div>
                <div class="loading-overlay" id="loadingOverlay">
                    <div class="spinner"></div>
                    <div class="loading-text">Rendering page...</div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── AI PANEL ── -->
    <div class="ai-panel">
        <div class="ai-header">
            <div class="ai-badge">
                <div class="ai-dot"></div>
                AI Assistant
            </div>
            <span class="ai-subtitle">Claude-powered</span>
        </div>
        <div class="ai-messages" id="aiMessages">
            <div class="ai-msg system">PDF loaded — analyzing structure...</div>
        </div>
        <div class="ai-input-area">
            <div class="ai-quick-btns">
                <button class="ai-quick" onclick="quickPrompt('Detect all fonts used')">🔤 Fonts</button>
                <button class="ai-quick" onclick="quickPrompt('Find signatures or logos')">✍️ Signatures</button>
                <button class="ai-quick" onclick="quickPrompt('Analyze table and calculate totals')">🔢 Calculate</button>
                <button class="ai-quick" onclick="quickPrompt('Add a new row to the table below the last row')">➕ Add row</button>
                <button class="ai-quick" onclick="quickPrompt('Redact sensitive information')">🔒 Redact</button>
            </div>
            <div class="ai-input-wrap">
                <textarea id="aiInput" placeholder="Tell me what you want to do..." rows="1"></textarea>
                <button class="ai-send-btn" onclick="sendAiMessage()">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5">
                        <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
                    </svg>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ── MODALS ── -->
<div class="modal-backdrop" id="textEditModal">
    <div class="modal">
        <div class="modal-title">
            Edit Text
            <button class="modal-close" onclick="closeModal('textEditModal')">×</button>
        </div>
        <div class="form-group">
            <label class="form-label">New Text</label>
            <textarea class="form-input" id="editNewText" rows="4" style="resize:vertical"></textarea>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label class="form-label">Font</label>
                <select class="form-select" id="editFont">
                    <option value="Helvetica">Helvetica</option>
                    <option value="Times-Roman">Times Roman</option>
                    <option value="Courier">Courier</option>
                    <option value="Helvetica-Bold">Helvetica Bold</option>
                    <option value="Times-Bold">Times Bold</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Size</label>
                <input class="form-input" id="editFontSize" type="number" value="10" min="4" max="96" step="0.5">
            </div>
            <div class="form-group">
                <label class="form-label">Color</label>
                <input class="form-input" id="editFontColor" type="color" value="#000000" style="padding:4px">
            </div>
        </div>
        <div class="modal-actions">
            <button class="btn-cancel" onclick="closeModal('textEditModal')">Cancel</button>
            <button class="btn-apply" onclick="applyTextEdit()">Apply Edit</button>
        </div>
    </div>
</div>

<!-- Context Menu -->
<div class="ctx-menu" id="ctxMenu">
    <div class="ctx-item" onclick="ctxEditText()">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        Edit Text
    </div>
    <div class="ctx-item" onclick="ctxCopyImage()">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
        Copy Region
    </div>
    <div class="ctx-item" onclick="ctxAskAI()">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3M12 17h.01"/></svg>
        Ask AI about this
    </div>
    <div class="ctx-sep"></div>
    <div class="ctx-item danger" onclick="ctxRedact()">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="9" x2="15" y2="15"/><line x1="15" y1="9" x2="9" y2="15"/></svg>
        Redact
    </div>
</div>

<div class="toast-container" id="toastContainer"></div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<script>
// ── Config ────────────────────────────────────────────────────────────────────
const DOC_ID = @Model.Id;
const TOTAL_PAGES = @Model.PageCount;
pdfjsLib.GlobalWorkerOptions.workerSrc =
    'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

// ── State ─────────────────────────────────────────────────────────────────────
let pdfDoc = null, currentPage = 1, currentZoom = 1.0;
let currentTool = 'select';
let selectionStart = null, selectionRect = null, isSelecting = false;
let selectedElement = null, currentAnalysis = null;
let aiHistory = [];
let pendingTextEdit = null;

// ── Init ──────────────────────────────────────────────────────────────────────
async function init() {
    await loadPdf();
    buildPageList();
    await analyzePage();
}

async function loadPdf() {
    try {
        pdfDoc = await pdfjsLib.getDocument(`/Editor/GetPdf/${DOC_ID}`).promise;
        await renderPage(currentPage);
    } catch (e) {
        toast('Failed to load PDF: ' + e.message, 'error');
    }
}

async function renderPage(pageNum) {
    if (!pdfDoc) return;
    showLoading(true);

    const page = await pdfDoc.getPage(pageNum);
    const viewport = page.getViewport({ scale: currentZoom });

    const canvas = document.getElementById('pdfCanvas');
    const overlay = document.getElementById('overlayCanvas');
    const viewport2 = document.getElementById('pdfViewport');

    canvas.width = viewport.width;
    canvas.height = viewport.height;
    overlay.width = viewport.width;
    overlay.height = viewport.height;
    viewport2.style.width = viewport.width + 'px';
    viewport2.style.height = viewport.height + 'px';

    await page.render({ canvasContext: canvas.getContext('2d'), viewport }).promise;

    document.getElementById('pageIndicator').textContent =
        `Page ${pageNum} / ${TOTAL_PAGES}`;

    clearOverlay();
    showLoading(false);
}

// ── Page list ─────────────────────────────────────────────────────────────────
function buildPageList() {
    const list = document.getElementById('pageList');
    list.innerHTML = '';
    for (let i = 1; i <= TOTAL_PAGES; i++) {
        const div = document.createElement('div');
        div.className = 'page-thumb' + (i === 1 ? ' active' : '');
        div.onclick = () => goToPage(i);
        div.innerHTML = `
            <div class="page-num-badge">${i}</div>
            <div class="page-thumb-label">Page ${i}</div>`;
        list.appendChild(div);
    }
}

function goToPage(n) {
    currentPage = n;
    document.querySelectorAll('.page-thumb').forEach((t, i) =>
        t.classList.toggle('active', i + 1 === n));
    renderPage(n);
    analyzePage();
}

function changePage(delta) {
    const newPage = Math.min(TOTAL_PAGES, Math.max(1, currentPage + delta));
    if (newPage !== currentPage) goToPage(newPage);
}

// ── Zoom ──────────────────────────────────────────────────────────────────────
function zoom(delta, mode) {
    if (mode === 'fit') currentZoom = 1.0;
    else currentZoom = Math.min(4, Math.max(0.25, currentZoom + delta));
    document.getElementById('zoomDisplay').textContent = Math.round(currentZoom * 100) + '%';
    renderPage(currentPage);
}

// ── Tools ─────────────────────────────────────────────────────────────────────
function setTool(t) {
    currentTool = t;
    document.querySelectorAll('.tb-btn[id^=tool]').forEach(b => b.classList.remove('active'));
    const btn = document.getElementById('tool' + t.charAt(0).toUpperCase() + t.slice(1));
    if (btn) btn.classList.add('active');
    document.getElementById('overlayCanvas').style.cursor =
        t === 'select' ? 'default' : 'crosshair';
}

// ── Selection on overlay canvas ───────────────────────────────────────────────
const overlay = document.getElementById('overlayCanvas');
overlay.addEventListener('mousedown', e => {
    if (currentTool === 'select') return;
    isSelecting = true;
    const r = overlay.getBoundingClientRect();
    selectionStart = { x: e.clientX - r.left, y: e.clientY - r.top };
    document.getElementById('selectionBox').style.display = 'block';
});

overlay.addEventListener('mousemove', e => {
    if (!isSelecting || !selectionStart) return;
    const r = overlay.getBoundingClientRect();
    const cx = e.clientX - r.left, cy = e.clientY - r.top;
    const box = document.getElementById('selectionBox');
    const x = Math.min(cx, selectionStart.x);
    const y = Math.min(cy, selectionStart.y);
    const w = Math.abs(cx - selectionStart.x);
    const h = Math.abs(cy - selectionStart.y);
    box.style.left = x + 'px'; box.style.top = y + 'px';
    box.style.width = w + 'px'; box.style.height = h + 'px';
    selectionRect = { x, y, w, h };
});

overlay.addEventListener('mouseup', () => {
    isSelecting = false;
    if (selectionRect && selectionRect.w > 5 && selectionRect.h > 5) {
        handleSelection(selectionRect);
    }
});

overlay.addEventListener('contextmenu', e => {
    e.preventDefault();
    if (selectionRect && selectionRect.w > 5) showContextMenu(e.clientX, e.clientY);
});

function handleSelection(rect) {
    const scale = currentZoom;
    const pdfRect = {
        x: rect.x / scale,
        y: rect.y / scale,
        w: rect.w / scale,
        h: rect.h / scale
    };

    if (currentTool === 'text') openTextEditModal(pdfRect);
    else if (currentTool === 'redact') performRedact(pdfRect);
    else if (currentTool === 'highlight') addHighlightAnnotation(pdfRect);
    else if (currentTool === 'annotate') openTextEditModal(pdfRect);
}

// ── Context Menu ──────────────────────────────────────────────────────────────
function showContextMenu(x, y) {
    const menu = document.getElementById('ctxMenu');
    menu.style.left = x + 'px'; menu.style.top = y + 'px';
    menu.style.display = 'block';
}
document.addEventListener('click', () => {
    document.getElementById('ctxMenu').style.display = 'none';
});

function ctxEditText() { if (selectionRect) openTextEditModal({x:selectionRect.x/currentZoom,y:selectionRect.y/currentZoom,w:selectionRect.w/currentZoom,h:selectionRect.h/currentZoom}); }
function ctxCopyImage() { if (selectionRect) performImageCopy(selectionRect); }
function ctxRedact() { if (selectionRect) performRedact({x:selectionRect.x/currentZoom,y:selectionRect.y/currentZoom,w:selectionRect.w/currentZoom,h:selectionRect.h/currentZoom}); }
function ctxAskAI() {
    if (!selectionRect) return;
    const msg = `Analyze the selected region at (${Math.round(selectionRect.x)}, ${Math.round(selectionRect.y)}) size ${Math.round(selectionRect.w)}x${Math.round(selectionRect.h)}`;
    sendAiMessage(msg);
}

// ── Text Edit Modal ───────────────────────────────────────────────────────────
function openTextEditModal(pdfRect) {
    pendingTextEdit = pdfRect;
    // Pre-fill from analysis if we can find matching text
    if (currentAnalysis) {
        const matching = currentAnalysis.textBlocks.find(tb =>
            Math.abs(tb.x - pdfRect.x) < 20 && Math.abs(tb.y - pdfRect.y) < 20);
        if (matching) {
            document.getElementById('editNewText').value = matching.text;
            document.getElementById('editFont').value = matching.fontName || 'Helvetica';
            document.getElementById('editFontSize').value = matching.fontSize || 10;
        }
    }
    document.getElementById('textEditModal').classList.add('open');
}

async function applyTextEdit() {
    if (!pendingTextEdit) return;
    const payload = {
        documentId: DOC_ID,
        pageNumber: currentPage,
        x: pendingTextEdit.x,
        y: pendingTextEdit.y,
        width: pendingTextEdit.w,
        height: pendingTextEdit.h,
        newText: document.getElementById('editNewText').value,
        fontName: document.getElementById('editFont').value,
        fontSize: parseFloat(document.getElementById('editFontSize').value),
        fontColor: document.getElementById('editFontColor').value
    };

    closeModal('textEditModal');
    showLoading(true);
    const r = await fetch('/Editor/EditText', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    });
    const d = await r.json();
    showLoading(false);
    if (d.success) {
        toast('Text updated — layout preserved ✓', 'success');
        await reloadAndRender();
    } else {
        toast('Error: ' + d.message, 'error');
    }
}

// ── Image Copy ────────────────────────────────────────────────────────────────
async function performImageCopy(rect) {
    const payload = {
        documentId: DOC_ID,
        sourcePage: currentPage,
        targetPage: currentPage,
        srcX: rect.x / currentZoom, srcY: rect.y / currentZoom,
        srcWidth: rect.w / currentZoom, srcHeight: rect.h / currentZoom,
        dstX: (rect.x / currentZoom) + 20,
        dstY: (rect.y / currentZoom) + 20,
        dstWidth: rect.w / currentZoom,
        dstHeight: rect.h / currentZoom
    };
    showLoading(true);
    const r = await fetch('/Editor/CopyImage', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    });
    const d = await r.json();
    showLoading(false);
    if (d.success) { toast('Image region copied ✓', 'success'); await reloadAndRender(); }
    else toast('Error: ' + d.message, 'error');
}

// ── Redact ────────────────────────────────────────────────────────────────────
async function performRedact(rect) {
    if (!confirm('Permanently redact this region?')) return;
    const payload = {
        documentId: DOC_ID, pageNumber: currentPage,
        x: rect.x, y: rect.y, w: rect.w, h: rect.h
    };
    showLoading(true);
    const r = await fetch('/Editor/Redact', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    });
    const d = await r.json();
    showLoading(false);
    if (d.success) { toast('Region redacted ✓', 'success'); await reloadAndRender(); }
    else toast('Error: ' + d.message, 'error');
}

// ── Analyze Page ──────────────────────────────────────────────────────────────
async function analyzePage() {
    try {
        const r = await fetch(`/Editor/Analyze/${DOC_ID}?page=${currentPage}`);
        const d = await r.json();
        if (d.success) {
            currentAnalysis = d.analysis;
            renderProperties(d.analysis);
            renderSuggestions(d.suggestions);
        }
    } catch (e) { console.warn('Analysis error:', e); }
}

function renderProperties(analysis) {
    const panel = document.getElementById('propsPanel');
    const fonts = analysis.fonts || [];
    const tables = analysis.tables || [];
    const images = analysis.images || [];

    panel.innerHTML = `
        <div class="prop-group">
            <div class="prop-label">Page</div>
            <div class="prop-value">${analysis.pageInfo?.width?.toFixed(0)} × ${analysis.pageInfo?.height?.toFixed(0)} pt</div>
        </div>
        <div class="prop-group">
            <div class="prop-label">Fonts Detected</div>
            <div>${fonts.slice(0,5).map(f =>
                `<span class="font-chip">${f.name} · ${f.size?.toFixed(1)}pt</span>`).join('')}</div>
        </div>
        <div class="prop-group">
            <div class="prop-label">Structure</div>
            <div class="prop-value">${analysis.textBlocks?.length || 0} text blocks · ${tables.length} table(s) · ${images.length} image(s)</div>
        </div>
        ${tables.length > 0 ? `
        <div class="prop-group">
            <div class="prop-label">Table Actions</div>
            <button class="ai-quick" onclick="calculateTotals(0)" style="margin:2px">🔢 Auto-calculate totals</button>
            <button class="ai-quick" onclick="addRowPrompt(0)" style="margin:2px">➕ Add row</button>
        </div>` : ''}
        ${images.some(i => i.possiblySignature) ? `
        <div class="prop-group">
            <div class="prop-label">Detected Elements</div>
            <div class="prop-value" style="color:#FF4D1C">✍️ Possible signature found</div>
        </div>` : ''}`;
}

function renderSuggestions(suggestions) {
    const list = document.createElement('ul');
    list.className = 'suggestions-list';
    (suggestions || []).forEach(s => {
        const li = document.createElement('li');
        li.className = 'suggestion-item';
        li.textContent = s;
        li.onclick = () => sendAiMessage(s.replace(/^[^ ]+ /, ''));
        list.appendChild(li);
    });
}

// ── Table operations ──────────────────────────────────────────────────────────
async function calculateTotals(tableIndex) {
    showLoading(true);
    const r = await fetch('/Editor/CalculateTotals', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ documentId: DOC_ID, pageNumber: currentPage, tableIndex })
    });
    const d = await r.json();
    showLoading(false);
    if (d.success) { toast('Totals calculated and filled ✓', 'success'); await reloadAndRender(); }
    else toast('Error: ' + d.message, 'error');
}

async function addRowPrompt(tableIndex) {
    const pos = prompt('Add row "above" or "below" last row?', 'below');
    if (!pos) return;
    const payload = {
        documentId: DOC_ID, pageNumber: currentPage,
        referenceRowY: 400, insertAbove: pos === 'above',
        referenceTableIndex: tableIndex
    };
    showLoading(true);
    const r = await fetch('/Editor/AddRow', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    });
    const d = await r.json();
    showLoading(false);
    if (d.success) { toast('Row added ✓', 'success'); await reloadAndRender(); }
    else toast('Error: ' + d.message, 'error');
}

// ── AI Chat ───────────────────────────────────────────────────────────────────
async function sendAiMessage(msg) {
    const input = document.getElementById('aiInput');
    const text = msg || input.value.trim();
    if (!text) return;

    input.value = '';
    appendAiMessage('user', text);
    aiHistory.push({ role: 'user', content: text });

    const typingEl = appendAiMessage('assistant', '···');

    try {
        const r = await fetch('/Editor/Chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                documentId: DOC_ID,
                pageNumber: currentPage,
                message: text,
                history: aiHistory.slice(-10)
            })
        });
        const d = await r.json();
        const response = d.response || 'No response';
        typingEl.innerHTML = formatAiResponse(response);
        aiHistory.push({ role: 'assistant', content: response });

        // Auto-execute detected operations
        const opMatch = response.match(/<operation>([\s\S]*?)<\/operation>/);
        if (opMatch) {
            try {
                const op = JSON.parse(opMatch[1]);
                showOperationCard(op, typingEl);
            } catch (e) {}
        }
    } catch (e) {
        typingEl.textContent = 'Error: ' + e.message;
    }

    document.getElementById('aiMessages').scrollTop = 9999;
}

function formatAiResponse(text) {
    // Remove operation tags from display
    text = text.replace(/<operation>[\s\S]*?<\/operation>/g, '');
    // Bold **text**
    text = text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
    // Monospace `code`
    text = text.replace(/`(.*?)`/g, '<code style="background:#0d0d14;padding:1px 4px;border-radius:3px;font-family:DM Mono,monospace">$1</code>');
    return text.trim();
}

function showOperationCard(op, parentEl) {
    const card = document.createElement('div');
    card.className = 'operation-card';
    card.innerHTML = `
        <div class="op-title">⚡ ${op.type?.toUpperCase().replace('_',' ')}</div>
        <div class="op-detail">${JSON.stringify(op.params || {}, null, 2).slice(0, 200)}</div>
        <button class="op-execute" onclick="executeAiOp(${JSON.stringify(op).replace(/"/g,'&quot;')})">
            Execute Operation →
        </button>`;
    parentEl.parentNode.insertBefore(card, parentEl.nextSibling);
}

async function executeAiOp(op) {
    const result = await fetch('/Editor/AiCommand', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            documentId: DOC_ID,
            pageNumber: currentPage,
            command: op.type,
            selectedRegionJson: JSON.stringify(op.params)
        })
    });
    const d = await result.json();
    if (d.success) { toast('AI operation complete ✓', 'success'); await reloadAndRender(); }
    else toast('Operation failed: ' + d.message, 'error');
}

function appendAiMessage(role, text) {
    const container = document.getElementById('aiMessages');
    const div = document.createElement('div');
    div.className = `ai-msg ${role}`;
    div.innerHTML = role === 'user' ? escapeHtml(text) : text;
    container.appendChild(div);
    container.scrollTop = 9999;
    return div;
}

function quickPrompt(text) { sendAiMessage(text); }

document.getElementById('aiInput').addEventListener('keydown', e => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendAiMessage(); }
});

// ── Image tools modal ─────────────────────────────────────────────────────────
function showImageTools() {
    if (!currentAnalysis) { toast('Analyze page first', 'info'); return; }
    const images = currentAnalysis.images || [];
    const msg = images.length > 0
        ? `Found ${images.length} image(s). ${images.filter(i=>i.possiblySignature).length} possible signature(s), ${images.filter(i=>i.possiblyLogo).length} possible logo(s). Select a region and right-click to copy.`
        : 'No images detected on this page.';
    sendAiMessage(msg);
}

// ── Version history ───────────────────────────────────────────────────────────
async function loadVersions() {
    const r = await fetch(`/Editor/Versions/${DOC_ID}`);
    const versions = await r.json();
    const list = document.getElementById('historyList');
    if (!versions.length) { list.innerHTML = '<p style="color:#555;font-size:12px;padding:20px 0;text-align:center">No versions yet</p>'; return; }
    list.innerHTML = versions.map(v => `
        <div class="history-item">
            <div class="history-dot"></div>
            <div>
                <div class="history-text">${v.label || 'Version ' + v.versionNumber}</div>
                <div class="history-time">${new Date(v.createdAt).toLocaleString()}</div>
                <button class="ai-quick" style="margin-top:4px" onclick="restoreVersion(${v.id})">Restore</button>
            </div>
        </div>`).join('');
    switchTab('history', document.querySelectorAll('.stab')[2]);
}

async function restoreVersion(verId) {
    if (!confirm('Restore this version? Current changes will be saved as a new version.')) return;
    const r = await fetch(`/Editor/RestoreVersion?documentId=${DOC_ID}&versionId=${verId}`, { method: 'POST' });
    const d = await r.json();
    if (d.success) { toast('Version restored ✓', 'success'); await reloadAndRender(); }
    else toast('Error: ' + d.message, 'error');
}

// ── Helpers ───────────────────────────────────────────────────────────────────
async function reloadAndRender() {
    // Reload the PDF from server and re-render
    pdfDoc = await pdfjsLib.getDocument({
        url: `/Editor/GetPdf/${DOC_ID}`,
        cacheKey: Date.now()
    }).promise;
    await renderPage(currentPage);
    await analyzePage();
    clearSelection();
}

function clearOverlay() {
    const ctx = document.getElementById('overlayCanvas').getContext('2d');
    ctx.clearRect(0, 0, ctx.canvas.width, ctx.canvas.height);
}

function clearSelection() {
    selectionRect = null; selectionStart = null;
    document.getElementById('selectionBox').style.display = 'none';
}

function closeModal(id) {
    document.getElementById(id).classList.remove('open');
}

function switchTab(name, btn) {
    document.querySelectorAll('.stab').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.stab-content').forEach(c => c.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('tab' + name.charAt(0).toUpperCase() + name.slice(1)).classList.add('active');
}

function showLoading(v) {
    document.getElementById('loadingOverlay').style.display = v ? 'flex' : 'none';
}

function toast(msg, type = 'info') {
    const tc = document.getElementById('toastContainer');
    const t = document.createElement('div');
    t.className = `toast ${type}`;
    t.innerHTML = (type === 'success' ? '✓ ' : type === 'error' ? '⚠ ' : 'ℹ ') + msg;
    tc.appendChild(t);
    setTimeout(() => t.remove(), 3500);
}

function escapeHtml(text) {
    return text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function undoLast() {
    sendAiMessage('Undo the last operation and restore the previous version');
}

function addHighlightAnnotation(rect) {
    fetch('/Editor/SaveAnnotations', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            documentId: DOC_ID,
            annotations: [{ pageNumber: currentPage, type: 'highlight', x: rect.x, y: rect.y, width: rect.w, height: rect.h, content: '', fontSize: 0, color: '#ffff00' }]
        })
    }).then(r => r.json()).then(d => {
        if (d.success) { toast('Highlight added ✓', 'success'); reloadAndRender(); }
    });
}

// ── Startup ───────────────────────────────────────────────────────────────────
init().then(() => {
    appendAiMessage('assistant', `I've loaded <strong>${@Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.FileName))}</strong> (${TOTAL_PAGES} page${TOTAL_PAGES > 1 ? 's' : ''}). I can help you edit text, detect fonts, copy signatures, analyze tables, and calculate totals — all while preserving the original formatting. What would you like to do?`);
});
</script>
}
